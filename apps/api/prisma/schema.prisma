// ============================================
// ARETON.id — Prisma Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ───────────────────────────────────

enum UserRole {
  CLIENT
  ESCORT
  ADMIN
  SUPER_ADMIN
}

enum EscortTier {
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ONGOING
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  ESCROW
  RELEASED
  REFUNDED
  FAILED
}

enum IncidentType {
  SOS
  COMPLAINT
  FEEDBACK
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum KycStatus {
  NONE
  PENDING
  IN_REVIEW
  VERIFIED
  REJECTED
}

enum KycDocumentType {
  KTP
  PASSPORT
  SIM
  KITAS
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

// ── Models ──────────────────────────────────

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  phone            String?   @unique
  passwordHash     String
  role             UserRole  @default(CLIENT)
  firstName        String
  lastName         String
  isVerified       Boolean   @default(false)
  isActive         Boolean   @default(true)
  emailVerifiedAt  DateTime?
  profilePhoto     String?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  referralCode     String?   @unique
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  escortProfile   EscortProfile?
  clientBookings  Booking[]        @relation("ClientBookings")
  escortBookings  Booking[]        @relation("EscortBookings")
  sentMessages    ChatMessage[]    @relation("SentMessages")
  givenReviews    Review[]         @relation("GivenReviews")
  receivedReviews Review[]         @relation("ReceivedReviews")
  notifications   Notification[]
  incidentReports  IncidentReport[] @relation("ReportedIncidents")
  favorites        Favorite[]       @relation("UserFavorites")
  favoritedBy      Favorite[]       @relation("FavoritedEscort")
  kycVerifications KycVerification[]
  refundClaims     RefundClaim[]    @relation("RefundClaims")
  withdrawals      Withdrawal[]
  referralsMade    Referral[]       @relation("ReferralsMade")
  referralReceived Referral?        @relation("ReferralReceived")
  articles         Article[]        @relation("AuthoredArticles")
  testimonials     Testimonial[]    @relation("UserTestimonials")
  dataExports      DataExportRequest[] @relation("DataExports")

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model EscortProfile {
  id                   String     @id @default(uuid())
  userId               String     @unique
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier                 EscortTier @default(SILVER)
  languages            String[]
  skills               String[]
  hourlyRate           Decimal    @db.Decimal(12, 2)
  ratingAvg            Float      @default(0)
  totalBookings        Int        @default(0)
  totalReviews         Int        @default(0)
  bio                  String?    @db.Text
  portfolioUrls        String[]
  videoIntroUrl        String?
  isApproved           Boolean    @default(false)
  approvedAt           DateTime?
  availabilitySchedule Json?

  // Physical appearance
  age                  String?    // e.g. "Late 20's", "Early 30's"
  height               String?    // e.g. "170cm"
  weight               String?    // e.g. "55kg"
  bodyType             String?    // e.g. "Slim", "Athletic", "Curvy"
  hairStyle            String?    // e.g. "Long & straight"
  eyeColor             String?    // e.g. "Brown", "Black"
  complexion           String?    // e.g. "Fair", "Olive", "Tan"

  // Personal background
  nationality          String?    // e.g. "Indonesian"
  occupation           String?    // e.g. "Model"
  fieldOfWork          String?    // e.g. "Fashion"
  basedIn              String?    // e.g. "Jakarta"
  travelScope          String?    // e.g. "Nationwide", "Worldwide"

  // Lifestyle
  smoking              String?    // "No", "Yes", "Occasionally"
  tattooPiercing       String?    // "None", description

  // Favourites (JSON)
  favourites           Json?      // { books, films, interests, sports, cuisine, drinks, perfume }

  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  // Relations
  certifications Certification[]

  @@index([tier])
  @@index([isApproved])
  @@index([ratingAvg])
  @@map("escort_profiles")
}

model Certification {
  id          String         @id @default(uuid())
  escortId    String
  escort      EscortProfile  @relation(fields: [escortId], references: [id], onDelete: Cascade)
  certType    String
  certName    String
  issuer      String
  validUntil  DateTime?
  documentUrl String
  isVerified  Boolean        @default(false)
  createdAt   DateTime       @default(now())

  @@index([escortId])
  @@map("certifications")
}

model Booking {
  id              String        @id @default(uuid())
  clientId        String
  client          User          @relation("ClientBookings", fields: [clientId], references: [id])
  escortId        String
  escort          User          @relation("EscortBookings", fields: [escortId], references: [id])
  serviceType     String
  status          BookingStatus @default(PENDING)
  startTime       DateTime
  endTime         DateTime
  location        String
  locationLat     Float?
  locationLng     Float?
  specialRequests String?       @db.Text
  totalAmount     Decimal       @db.Decimal(12, 2)
  checkinAt       DateTime?
  checkoutAt      DateTime?
  cancelledAt     DateTime?
  cancelledBy     String?
  cancelReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Transaction Lock
  replacementRequested Boolean @default(false)
  replacementNote      String?

  // Relations
  payment      Payment?
  messages     ChatMessage[]
  reviews      Review[]
  incidents    IncidentReport[]
  refundClaims RefundClaim[]

  @@index([clientId])
  @@index([escortId])
  @@index([status])
  @@index([startTime])
  @@map("bookings")
}

model Payment {
  id                String        @id @default(uuid())
  bookingId         String        @unique
  booking           Booking       @relation(fields: [bookingId], references: [id])
  amount            Decimal       @db.Decimal(12, 2)
  method            String
  status            PaymentStatus @default(PENDING)
  forfeited         Boolean       @default(false)
  paymentType       String        @default("FULL") // FULL or DP_50
  platformFee       Decimal       @db.Decimal(12, 2)
  escortPayout      Decimal       @db.Decimal(12, 2)
  tipAmount         Decimal?      @db.Decimal(12, 2)
  paymentGatewayRef String?
  paidAt            DateTime?
  releasedAt        DateTime?
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  refundClaims      RefundClaim[]

  @@index([status])
  @@map("payments")
}

model Review {
  id                   String   @id @default(uuid())
  bookingId            String
  booking              Booking  @relation(fields: [bookingId], references: [id])
  reviewerId           String
  reviewer             User     @relation("GivenReviews", fields: [reviewerId], references: [id])
  revieweeId           String
  reviewee             User     @relation("ReceivedReviews", fields: [revieweeId], references: [id])
  rating               Int      // 1-5
  comment              String?  @db.Text
  attitudeScore        Int?     // 1-5
  punctualityScore     Int?     // 1-5
  professionalismScore Int?     // 1-5
  replyComment         String?  @db.Text
  repliedAt            DateTime?
  isFlagged            Boolean  @default(false)
  createdAt            DateTime @default(now())

  @@unique([bookingId, reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}

model ChatMessage {
  id        String      @id @default(uuid())
  bookingId String
  booking   Booking     @relation(fields: [bookingId], references: [id])
  senderId  String
  sender    User        @relation("SentMessages", fields: [senderId], references: [id])
  content   String      @db.Text // encrypted
  type      MessageType @default(TEXT)
  readAt    DateTime?
  createdAt DateTime    @default(now())

  @@index([bookingId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

model IncidentReport {
  id               String       @id @default(uuid())
  bookingId        String
  booking          Booking      @relation(fields: [bookingId], references: [id])
  reporterId       String
  reporter         User         @relation("ReportedIncidents", fields: [reporterId], references: [id])
  type             IncidentType
  description      String       @db.Text
  severity         Int          // 1-5
  evidence         Json?        // Array of evidence file URLs
  resolutionStatus String       @default("OPEN")
  adminNotes       String?      @db.Text
  resolvedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([type])
  @@index([resolutionStatus])
  @@map("incident_reports")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String   // BOOKING, PAYMENT, CHAT, SAFETY, SYSTEM
  data      Json?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  escortId  String
  escort    User     @relation("FavoritedEscort", fields: [escortId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, escortId])
  @@map("favorites")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String   // LOGIN, LOGOUT, SOS_TRIGGER, PAYMENT, ADMIN_ACTION, DATA_ACCESS, PROFILE_UPDATE, etc.
  resource   String   // users, bookings, payments, etc.
  resourceId String?
  details    Json?    // Action-specific metadata
  ipAddress  String?
  userAgent  String?
  severity   String   @default("INFO") // INFO, WARN, CRITICAL
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model PromoCode {
  id             String    @id @default(uuid())
  code           String    @unique
  description    String?
  discountType   String    // PERCENTAGE, FIXED
  discountValue  Decimal   @db.Decimal(12, 2)
  minOrderAmount Decimal?  @db.Decimal(12, 2)
  maxDiscount    Decimal?  @db.Decimal(12, 2)
  usageLimit     Int?
  usageCount     Int       @default(0)
  validFrom      DateTime
  validUntil     DateTime
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
  @@map("promo_codes")
}

// ── Corporate Subscription ─────────────────

model CorporateSubscription {
  id              String   @id @default(uuid())
  companyName     String
  contactPerson   String
  contactEmail    String
  contactPhone    String?
  plan            String   // BASIC, PROFESSIONAL, ENTERPRISE
  maxUsers        Int      @default(5)
  monthlyBudget   Decimal  @db.Decimal(12, 2)
  usedBudget      Decimal  @default(0) @db.Decimal(12, 2)
  discountPercent Int      @default(0)
  features        Json?    // { priorityBooking, dedicatedManager, invoicing, etc. }
  status          String   @default("ACTIVE") // ACTIVE, SUSPENDED, EXPIRED
  startDate       DateTime
  endDate         DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members CorporateMember[]

  @@index([status])
  @@index([companyName])
  @@map("corporate_subscriptions")
}

model CorporateMember {
  id             String                @id @default(uuid())
  subscriptionId String
  subscription   CorporateSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  userId         String
  role           String                @default("MEMBER") // ADMIN, MEMBER
  joinedAt       DateTime              @default(now())

  @@unique([subscriptionId, userId])
  @@map("corporate_members")
}

// ── Training Center ────────────────────────

model TrainingModule {
  id            String   @id @default(uuid())
  title         String
  description   String   @db.Text
  category      String   // ONBOARDING, ETIQUETTE, SAFETY, COMMUNICATION, ADVANCED
  videoUrl      String?
  thumbnailUrl  String?
  durationMins  Int      @default(0)
  sortOrder     Int      @default(0)
  isRequired    Boolean  @default(false)
  isPublished   Boolean  @default(true)
  passingScore  Int      @default(70)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  progress TrainingProgress[]

  @@index([category])
  @@index([isPublished])
  @@map("training_modules")
}

model TrainingProgress {
  id             String         @id @default(uuid())
  userId         String
  moduleId       String
  module         TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  status         String         @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  progressPct    Int            @default(0)
  score          Int?
  completedAt    DateTime?
  startedAt      DateTime       @default(now())
  lastAccessedAt DateTime       @default(now())

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([status])
  @@map("training_progress")
}

// ── Refund Claims ──────────────────────────

enum RefundClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model RefundClaim {
  id          String            @id @default(uuid())
  paymentId   String
  payment     Payment           @relation(fields: [paymentId], references: [id])
  bookingId   String
  booking     Booking           @relation(fields: [bookingId], references: [id])
  requesterId String
  requester   User              @relation("RefundClaims", fields: [requesterId], references: [id])
  reason      String            @db.Text
  evidence    Json?
  status      RefundClaimStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  handledAt   DateTime?
  handledBy   String?

  @@index([bookingId])
  @@index([paymentId])
  @@index([status])
  @@map("refund_claims")
}

// ── Premium Listing ────────────────────────

model PremiumListing {
  id            String    @id @default(uuid())
  escortId      String
  type          String    // FEATURED, SPOTLIGHT, TOP_PICK
  startDate     DateTime
  endDate       DateTime
  amount        Decimal   @db.Decimal(12, 2)
  isActive      Boolean   @default(true)
  impressions   Int       @default(0)
  clicks        Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([escortId])
  @@index([type, isActive])
  @@index([endDate])
  @@map("premium_listings")
}

// ── eKYC Verification ──────────────────────

model KycVerification {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           KycStatus       @default(PENDING)
  documentType     KycDocumentType @default(KTP)
  documentNumber   String?         // Encrypted KTP/Passport number
  documentFrontUrl String?         // Front side of ID document
  documentBackUrl  String?         // Back side of ID (KTP only)
  selfieUrl        String?         // Selfie for face matching
  livenessScore    Float?          // 0-100 liveness detection score
  faceMatchScore   Float?          // 0-100 face match vs ID photo
  ocrData          Json?           // Extracted data from ID (name, NIK, DOB, address)
  providerRef      String?         // External provider reference ID
  providerResponse Json?           // Raw response from eKYC provider
  rejectionReason  String?
  reviewedBy       String?         // Admin user ID who reviewed
  reviewedAt       DateTime?
  verifiedAt       DateTime?
  expiresAt        DateTime?       // Document expiry date
  attemptNumber    Int             @default(1)
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("kyc_verifications")
}

// ── Referral System ─────────────────────────

model Referral {
  id              String    @id @default(uuid())
  referrerId      String
  referrer        User      @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId      String    @unique
  referred        User      @relation("ReferralReceived", fields: [referredId], references: [id], onDelete: Cascade)
  referralCode    String
  rewardAmount    Decimal   @default(0) @db.Decimal(12, 2)
  rewardClaimed   Boolean   @default(false)
  claimedAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([referrerId])
  @@index([referralCode])
  @@map("referrals")
}

// ── Blog / Articles ────────────────────────

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Article {
  id          String        @id @default(uuid())
  authorId    String
  author      User          @relation("AuthoredArticles", fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  slug        String        @unique
  excerpt     String?       @db.Text
  content     String        @db.Text
  coverImage  String?
  category    String        @default("tips")
  tags        String[]
  status      ArticleStatus @default(DRAFT)
  viewCount   Int           @default(0)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([authorId])
  @@index([category])
  @@map("articles")
}

// ── Testimonial ────────────────────────────

model Testimonial {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserTestimonials", fields: [userId], references: [id], onDelete: Cascade)
  content     String   @db.Text
  rating      Int      // 1-5
  isApproved  Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  approvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([isApproved, isFeatured])
  @@map("testimonials")
}

// ── Data Export (GDPR/UU PDP) ──────────────

enum DataExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  EXPIRED
}

model DataExportRequest {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation("DataExports", fields: [userId], references: [id], onDelete: Cascade)
  status      DataExportStatus @default(PENDING)
  format      String           @default("json") // json or csv
  downloadUrl String?
  expiresAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime         @default(now())

  @@index([userId])
  @@index([status])
  @@map("data_export_requests")
}

// ── Withdrawals ──────────────────────────────

model Withdrawal {
  id              String           @id @default(uuid())
  escortId        String
  escort          User             @relation(fields: [escortId], references: [id], onDelete: Cascade)
  amount          Decimal          @db.Decimal(12, 2)
  bankName        String
  bankAccount     String
  accountHolder   String?
  status          WithdrawalStatus @default(PENDING)
  rejectionReason String?
  processedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([escortId])
  @@index([status])
  @@index([createdAt])
  @@map("withdrawals")
}
