# ============================================
# ARETON.id — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
# Dev ports: web `npm run dev` -> 3000, admin `npm run dev` -> 3001
# Prod / PM2 ports: web -> 3003, admin -> 3005
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
# Optional explicit CORS allow-list (comma-separated). Overrides WEB_URL/ADMIN_URL.
# Example: CORS_ORIGINS=https://areton.id,https://admin.areton.id
CORS_ORIGINS=
ENABLE_PAYMENT_MOCK=false
NEXT_PUBLIC_ENABLE_PAYMENT_MOCK=false

# ── Database (PostgreSQL) ────────────────────
DATABASE_URL=postgresql://areton:areton_dev_2026@localhost:5432/areton_db?schema=public

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────
JWT_ACCESS_SECRET=areton-access-secret-change-in-production
JWT_REFRESH_SECRET=areton-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── OAuth — Google ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ── OAuth — Apple Sign-in ────────────────────
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ── eKYC Provider (Verihubs/VIDA/Privy) ──────
EKYC_API_KEY=
EKYC_API_URL=https://api.verihubs.com/v1
EKYC_ENCRYPTION_KEY=

# ── Payment Gateway — Xendit (fiat, dormant) ─
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# ── Payment Gateway — Crypto (NOWPayments) ───
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ── Payment Gateway — DOKU ───────────────────
DOKU_CLIENT_ID=
DOKU_SECRET_KEY=
DOKU_PUBLIC_KEY=

# ── AWS S3 ───────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=areton-media-dev

# ── Firebase (Push Notification) ─────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── Twilio (SMS / WhatsApp) ──────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ── Brevo (Email) ────────────────────────────
BREVO_API_KEY=
EMAIL_FROM=noreply@areton.id
EMAIL_FROM_NAME=ARETON.id

# ── Google Maps ──────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Sentry (Error Tracking) ─────────────────
SENTRY_DSN=

# ── Encryption ───────────────────────────────
ENCRYPTION_KEY=change-this-to-32-byte-random-key

# ── Feature flags (Phase 2+ modules) ─────────
# All default to `true` when unset. Set to `false` / `0` to disable.
# Disabled modules are not loaded into the NestJS container, which also
# means their routes are not registered.
ENABLE_MATCHING=true
ENABLE_CORPORATE=true
ENABLE_TRAINING=true
ENABLE_PREMIUM=true
ENABLE_REFERRAL=true
ENABLE_ARTICLES=true
ENABLE_TESTIMONIALS=true
ENABLE_GDPR=true
ENABLE_ANALYTICS=true
