{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [{
        "expr": "sum(rate(areton_http_requests_total[5m]))",
        "legendFormat": "Total"
      }, {
        "expr": "sum(rate(areton_http_requests_total[5m])) by (method)",
        "legendFormat": "{{method}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Error Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 0 },
      "targets": [{
        "expr": "sum(rate(areton_http_errors_total[5m])) / sum(rate(areton_http_requests_total[5m])) * 100",
        "legendFormat": "Error %"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "max": 100,
          "unit": "percent"
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(areton_http_request_duration_seconds_bucket[5m])) by (le))",
        "legendFormat": "p95"
      }, {
        "expr": "histogram_quantile(0.50, sum(rate(areton_http_request_duration_seconds_bucket[5m])) by (le))",
        "legendFormat": "p50"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [{
        "expr": "areton_active_connections",
        "legendFormat": "HTTP"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 4 },
      "targets": [{
        "expr": "areton_websocket_connections",
        "legendFormat": "WS"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Requests by Route (Top 10)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{
        "expr": "topk(10, sum(rate(areton_http_requests_total[5m])) by (route))",
        "legendFormat": "{{route}}",
        "format": "table",
        "instant": true
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Error by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{
        "expr": "sum(rate(areton_http_errors_total[5m])) by (route, status_code)",
        "legendFormat": "{{route}} ({{status_code}})"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Bookings Created",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [{
        "expr": "increase(areton_bookings_total[1h])",
        "legendFormat": "{{status}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Payments Processed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [{
        "expr": "increase(areton_payments_total[1h])",
        "legendFormat": "{{status}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Notifications Sent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [{
        "expr": "increase(areton_notifications_sent_total[1h])",
        "legendFormat": "{{channel}} - {{type}}"
      }],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "targets": [{
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "CPU %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "targets": [{
        "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
        "legendFormat": "Used"
      }, {
        "expr": "node_memory_MemAvailable_bytes",
        "legendFormat": "Available"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "targets": [{
        "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
        "legendFormat": "Disk %"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          },
          "max": 100,
          "unit": "percent"
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Node.js Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [{
        "expr": "areton_nodejs_heap_size_used_bytes",
        "legendFormat": "Heap Used"
      }, {
        "expr": "areton_nodejs_heap_size_total_bytes",
        "legendFormat": "Heap Total"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [{
        "expr": "areton_nodejs_eventloop_lag_seconds",
        "legendFormat": "Lag"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Database Query Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(areton_db_query_duration_seconds_bucket[5m])) by (le, model))",
        "legendFormat": "{{model}}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [{
        "expr": "sum(rate(areton_cache_hits_total[5m])) / (sum(rate(areton_cache_hits_total[5m])) + sum(rate(areton_cache_misses_total[5m]))) * 100",
        "legendFormat": "Hit Rate %"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "max": 100,
          "unit": "percent"
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["areton", "api", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Jakarta",
  "title": "ARETON.id — API Monitoring",
  "uid": "areton-api-dashboard",
  "version": 1
}
